# Supabase Credentials Configuration
# Inserir as credenciais do seu projeto Supabase abaixo. Elas serão utilizadas pelo cliente React para sync em tempo real.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Alternativa (Next/Supabase):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Configurações de SMTP para Envio Real de E-mails de Recuperação de Senha
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu-usuario@exemplo.com
SMTP_PASS=sua-senha-smtp
SMTP_FROM=suporte-sistema@admincore.com.br

